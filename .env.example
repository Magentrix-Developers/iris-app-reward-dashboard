# Copy this file to .env.development for local development
# Never commit .env.development — it contains your refresh token

# Your Magentrix portal URL
VITE_SITE_URL=https://your-portal.magentrixcloud.com

# Refresh token for local dev auth (obtain from your portal profile)
VITE_REFRESH_TOKEN=your_refresh_token_here

# Portal CSS assets (paste the array from your portal's iris.css link chain)
VITE_ASSETS='["https://your-portal.magentrixcloud.com/contents/css/main/iris.css"]'
